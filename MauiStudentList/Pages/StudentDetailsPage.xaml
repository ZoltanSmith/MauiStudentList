<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mtf="clr-namespace:Mtf.Maui.Controls;assembly=Mtf.Maui.Controls" xmlns:viewmodel="clr-namespace:MauiStudentList.ViewModel" x:DataType="viewmodel:StudentViewModel"
             x:Class="MauiStudentList.StudentDetailsPage">
    
    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="user_img.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />
            <Editor>
                
            </Editor>

            <HorizontalStackLayout>
                <Label
                    Text="Név:"
                    Style="{StaticResource Label}"
                    />

                <Entry
                    Style="{StaticResource Input}"
                    Text="{Binding Name, Mode=TwoWay}"
                    />
            </HorizontalStackLayout>

            <HorizontalStackLayout>
                <Label
                    Text="Kor:"
                    Style="{StaticResource Label}"
                    />

                <mtf:NumericUpDownWithLabel
                    Value="{Binding Kor}"
                    />
            </HorizontalStackLayout>

            <HorizontalStackLayout>
                <Label
                    Text="Város:"
                    Style="{StaticResource Label}"
                    />

                <Entry
                    x:Name="City"
                    Style="{StaticResource Input}"
                    Text="{Binding Varos}"
                    >
                    <Entry.GestureRecognizers>
                        <TapGestureRecognizer Tapped="TapGestureRecognizer_City_Tapped" NumberOfTapsRequired="1"/>
                    </Entry.GestureRecognizers>
                </Entry>
            </HorizontalStackLayout>

            <HorizontalStackLayout>
                <Label
                    Text="Van jogosítványa:"
                    Style="{StaticResource Label}"
                >
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped" NumberOfTapsRequired="1"/>
                    </Label.GestureRecognizers>
                </Label>
                <mtf:CheckBoxWithLabel
                    x:Name="DriverLicenceCb"
                    />
            </HorizontalStackLayout>

            <Button
                x:Name="SaveBtn"
                Text="Mentés" 
                Clicked="SaveBtn_Clicked"
                Command="{Binding SaveCommand}"
                HorizontalOptions="Fill" />
            <Button
                x:Name="ModBtn"
                Text="Módosítás" 
                Clicked="ModBtn_Clicked"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
